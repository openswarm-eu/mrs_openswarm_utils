<launch>

  <arg name="UAV_NAME" default="$(optenv UAV_NAME uav1)"/>
  <arg name="global_map_topic" default="global_map"/>
  <arg name="allow_empty_response" default="false"/>
  <arg name="target_frame" default=""/>
  <arg name="tf_timeout" default="0.2"/>

  <group ns="$(arg UAV_NAME)">
    <node pkg="mrs_openswarm_utils" type="global_map_provider" name="global_map_provider" output="screen">
      <param name="global_map_topic" value="$(arg global_map_topic)"/>
      <param name="allow_empty_response" value="$(arg allow_empty_response)"/>
      <param name="target_frame" value="$(arg target_frame)"/>
      <param name="tf_timeout" value="$(arg tf_timeout)"/>
    </node>
  </group>

</launch>

